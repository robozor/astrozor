# Normalize line endings — LF in repo, native in working tree
* text=auto eol=lf

# Always LF — shell scripts, Docker, configs
*.sh         text eol=lf
*.bash       text eol=lf
Dockerfile   text eol=lf
Dockerfile.* text eol=lf
*.yaml       text eol=lf
*.yml        text eol=lf
*.json       text eol=lf
Caddyfile    text eol=lf
Makefile     text eol=lf

# Always CRLF — Windows scripts
*.bat        text eol=crlf
*.cmd        text eol=crlf
*.ps1        text eol=crlf

# Binary — no diff/merge
*.png        binary
*.jpg        binary
*.gif        binary
*.ico        binary
*.pdf        binary
*.zip        binary
*.fits       binary
