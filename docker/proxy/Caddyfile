# Astrozor reverse proxy — Caddy
# Local dev: HTTP on :80 mapping astrozor.localhost to internal services.
# Production: TLS via Let's Encrypt (configured via env variable).

{
    # Disable auto-HTTPS for localhost — we use plain HTTP locally.
    auto_https off
    admin off
}

# Local dev hostnames
:80, astrozor.localhost, localhost, 127.0.0.1 {
    # API → Django (django.contrib.admin is not exposed; product admin
    # lives under /api/v1/admin/* and is consumed by the React UI).
    handle /api/* {
        reverse_proxy api:8000
    }
    handle /static/* {
        reverse_proxy api:8000
    }
    # Public discoverability surfaces — RSS/Atom feed of articles and
    # the server-rendered per-article HTML page that emits OG /
    # JSON-LD meta tags for social-network crawlers. The latter then
    # redirects browsers to the SPA via <meta refresh>.
    handle /articles.atom {
        reverse_proxy api:8000
    }
    handle /articles.rss {
        reverse_proxy api:8000
    }
    handle /clanky/* {
        reverse_proxy api:8000
    }
    handle /sitemap.xml {
        reverse_proxy api:8000
    }
    handle /robots.txt {
        reverse_proxy api:8000
    }
    # Pre-rendered Quarto/RMarkdown/Jupyter bundles. Served by Caddy
    # file_server (bypassing Django) for two reasons:
    #   1) Django SecurityMiddleware sets X-Frame-Options: DENY on every
    #      response, which blocks the same-origin iframe in ArticlesPage.
    #   2) Bundles can be tens of MB with many small files — sendfile
    #      from Linux is faster than Python static_serve.
    # Path is /media/quarto/<user_id>/<slug>/index.html (+ siblings);
    # mapped to /srv/media/quarto/... via the astrozor_media:ro mount.
    # Caddy matches `handle_path` in declaration order, so we put this
    # BEFORE the generic /media/* fallback below.
    handle_path /media/quarto/* {
        root * /srv/media/quarto
        file_server
        # index.html may be overwritten on republish (idempotent slug) —
        # browser must revalidate to avoid serving a stale top doc with
        # a now-removed asset reference. Other files (figures, CSS) are
        # versioned via Quarto's _files/<hash>/ paths and can cache long.
        @html path *.html
        header @html Cache-Control "no-cache, must-revalidate"
        header Cache-Control "public, max-age=86400"
        # We intentionally do NOT set X-Frame-Options here; the parent
        # SPA needs same-origin iframe access for plotly/MathJax hover
        # and our auto-resize postMessage workflow.
    }
    handle /media/* {
        reverse_proxy api:8000
    }
    # Serve self-hosted tile caches directly with Caddy's file_server.
    # Critical for PMTiles: the 130 GB archive uses HTTP Range requests
    # — sendfile-based serving keeps memory flat regardless of file size.
    # Routing the same paths through Django (api) was killing the VM
    # because static_serve doesn't fit a 130 GB hot path.
    handle_path /pmtiles/* {
        root * /srv/pmtiles
        file_server {
            precompressed gzip
        }
        # 30 days cache + immutable: tile bytes inside a build never change
        header Cache-Control "public, max-age=2592000, immutable"
        # CORS so MapLibre can fetch from any origin if frontend is split out
        header Access-Control-Allow-Origin "*"
    }
    handle_path /lp-tiles/* {
        root * /srv/lp-tiles
        file_server
        header Cache-Control "public, max-age=2592000, immutable"
        header Access-Control-Allow-Origin "*"
    }
    # CRAN-like R package repo. The `astrozorpub` source tarball lives
    # at /R/src/contrib/ along with a PACKAGES index, generated by the
    # r-pkg-builder one-shot service from rstudio-addin/ on each
    # `docker compose up`. Users run:
    #   install.packages("astrozorpub", repos = "https://<host>/R")
    # `browse` enables directory listing so users can verify what's
    # available when troubleshooting.
    handle_path /R/* {
        root * /srv/r-repo
        file_server browse
        header Cache-Control "public, max-age=300"
    }
    # VS Code extension .vsix repo. Populated by the vsce-pkg-builder
    # one-shot service from vscode-extension/. Stable URL for the latest
    # build:
    #     <host>/vscode-extension/astrozor-publish-latest.vsix
    # Plus a JSON index for the backend /vscode-pkg/info endpoint.
    handle_path /vscode-extension/* {
        root * /srv/vsce-repo
        file_server browse
        header Cache-Control "public, max-age=300"
    }
    # Sample article sources (.md, .qmd, .ipynb) — bind-mounted from
    # samples/ repo dir. Users download these from the docs pages, render
    # locally, and publish back via the addins to verify their toolchain.
    handle_path /samples/* {
        root * /srv/samples
        file_server browse
        header Cache-Control "public, max-age=600"
    }

    # Everything else → Vite dev server (frontend)
    handle {
        reverse_proxy frontend:5173 {
            # Vite uses HMR over WS — Caddy upgrades automatically when Connection: upgrade
            transport http {
                versions 1.1 2
            }
        }
    }

    encode gzip
    log {
        output stdout
        format console
    }
}
