# Astrozor — environment variables example.
# Copy to .env, fill in real values, never commit .env.
#
# Each integration block links to the upstream console where you
# generate the credentials. Redirect URI for OAuth providers always
# follows the pattern:
#     https://<HOST>/api/v1/auth/<provider>/callback
# For local dev replace <HOST> with `astrozor.localhost`.

# ============================================================
# Production deploy — only used by docker-compose.prod.yml
# ============================================================
# Skip this section for local dev. See docs/deploy-synology.md for full
# walkthrough. ASTROZOR_TAG controls which release is pulled from GHCR
# (use `latest` or pin to a version like v1.2.0).
ASTROZOR_TAG=latest
ASTROZOR_IMAGE_OWNER=robozor
ASTROZOR_DOMAIN=astrozor.localhost
ASTROZOR_HTTP_PORT=80
ASTROZOR_HTTPS_PORT=443
# SITE_ADDRESS controls Caddy's site block — see deploy-synology.md §4.
#   :80                          → HTTP only (DSM / external proxy does TLS)
#   astrozor.example.com         → auto Let's Encrypt
#   astrozor.example.com:8443    → LE on a custom port
SITE_ADDRESS=:80
TZ=Europe/Prague
# PUBLIC_BASE_URL is used by OAuth callbacks, RSS feeds, Discord
# webhooks, etc. Must match the public-facing URL.
PUBLIC_BASE_URL=http://astrozor.localhost
# Gunicorn / Celery tuning (prod only).
GUNICORN_WORKERS=3
GUNICORN_TIMEOUT=60
CELERY_CONCURRENCY=2

# ============================================================
# Django
# ============================================================
DJANGO_SECRET_KEY=insecure-dev-secret-change-me-in-production
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,astrozor.localhost,api,proxy
DJANGO_CSRF_TRUSTED_ORIGINS=http://astrozor.localhost,http://localhost

# ============================================================
# Database (PostgreSQL + PostGIS)
# ============================================================
POSTGRES_DB=astrozor
POSTGRES_USER=astrozor
POSTGRES_PASSWORD=astrozor

# ============================================================
# Feature toggles
# ============================================================
# Set to "false" to disable the publish API on this self-host instance.
PUBLIC_PUBLISH_API_ENABLED=true

# ============================================================
# OAuth providers — login modal
# ============================================================
# Each block has the console URL + the exact redirect URI to paste in.

# ---- GitHub ----
# Console: https://github.com/settings/developers  →  "New OAuth App"
# Redirect URI: http://astrozor.localhost/api/v1/auth/github/callback
# Scopes: read:user, user:email
# GITHUB_OAUTH_CLIENT_ID=
# GITHUB_OAUTH_CLIENT_SECRET=

# ---- Google ----
# Console: https://console.cloud.google.com/apis/credentials  →  "Create Credentials → OAuth client ID"
# Type: Web application
# Authorized redirect URIs: http://astrozor.localhost/api/v1/auth/google/callback
# Required: enable Google+ API or "Google People API" first (auto on new projects)
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=

# ---- GitLab ----
# Console: https://gitlab.com/-/user_settings/applications  →  "Add new application"
# Redirect URI: http://astrozor.localhost/api/v1/auth/gitlab/callback
# Confidential: yes  ·  Scopes: read_user
# For self-hosted GitLab, override the base URL (defaults to gitlab.com).
# GITLAB_OAUTH_CLIENT_ID=
# GITLAB_OAUTH_CLIENT_SECRET=
# GITLAB_OAUTH_BASE_URL=https://git.example.com

# ---- Discord (identity OAuth + Astrozor bot install) ----
# Console: https://discord.com/developers/applications  →  New Application "Astrozor Events"
#   1. OAuth2 → General → copy Client ID + Client Secret
#   2. OAuth2 → Redirects → add: http://astrozor.localhost/api/v1/auth/discord/callback
#      (and the production URL when deploying)
#   3. Bot → Add Bot → Reset Token → copy Bot Token (shown ONCE — save now)
#   4. Bot → Privileged Gateway Intents: leave all OFF (no message reading needed)
#   5. Optional: Bot → Public Bot — leave ON so any user can install it in their server
# Bot permissions used: Manage Channels (0x10) + Create Instant Invite (0x01) = 17
# OAuth scopes used: identify + email + bot
# DISCORD_APP_CLIENT_ID=
# DISCORD_APP_CLIENT_SECRET=
# DISCORD_BOT_TOKEN=

# ---- Zooniverse (Citizen Science integration) ----
# Console: https://panoptes.zooniverse.org/oauth/applications  →  "New Application"
# Redirect URI: http://astrozor.localhost/api/v1/auth/zooniverse/callback
# Confidential: yes
# Scopes ticked: User · Project · Group · Classification
# (do NOT tick Collection / Subject / Medium / Organization / Translation —
#  Astrozor doesn't use them, narrower surface = safer if creds leak)
# ZOONIVERSE_OAUTH_CLIENT_ID=
# ZOONIVERSE_OAUTH_CLIENT_SECRET=
# ZOONIVERSE_GROUP_ID=

# ---- Mastodon (not in login modal — used for cross-posting from Settings) ----
# Per-instance OAuth app registration happens dynamically when a user adds
# their instance in Settings → Connected accounts. No global env vars
# needed — each (instance, app) pair is stored in the DB.

# ============================================================
# OAuth endpoint overrides (E2E test fixtures only — leave blank in prod)
# ============================================================
# GITHUB_OAUTH_AUTHORIZE_URL=
# GITHUB_OAUTH_TOKEN_URL=
# GITHUB_OAUTH_USER_URL=
# GITHUB_OAUTH_EMAILS_URL=

# ============================================================
# Zenodo (DOI minting for published articles)
# ============================================================
# Sandbox (for development): https://sandbox.zenodo.org/account/settings/applications/tokens/new
# Production:                https://zenodo.org/account/settings/applications/tokens/new
# Scopes: deposit:actions, deposit:write
# Astrozor uses sandbox when DJANGO_DEBUG=true, else production.
# ZENODO_SANDBOX_TOKEN=
# ZENODO_PROD_TOKEN=

# ============================================================
# Discord (test webhook for /admin/notifications dry-run)
# ============================================================
# Server settings → Integrations → Webhooks → New Webhook → Copy URL
# Format: https://discord.com/api/webhooks/<id>/<token>
# Per-user webhooks live in DB (Settings → Discord notifications), this
# is only the global test/dry-run target.
# DISCORD_TEST_WEBHOOK_URL=

# ============================================================
# GitHub access token (rate-limit-friendly fetches for admin polling
# of upstream Protomaps releases, etc.)
# ============================================================
# Create at: https://github.com/settings/tokens (Personal access tokens → Fine-grained or classic)
# Scopes needed: public_repo (read only) — no write access required.
# GITHUB_TOKEN=

# ============================================================
# Web Push (browser push notifications)
# ============================================================
# Generate VAPID key pair (one-time, then paste here):
#   docker compose run --rm api python -c "from py_vapid import Vapid; \
#       v = Vapid(); v.generate_keys(); \
#       v.save_key('/tmp/vapid_private.pem'); \
#       v.save_public_key('/tmp/vapid_public.pem')"
# Then read the keys from /tmp/vapid_*.pem and paste below.
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_ADMIN_EMAIL=admin@astrozor.cz
