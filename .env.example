# Astrozor — environment variables example
# Copy to .env, adjust values, never commit .env.

# ---- Django ----
DJANGO_SECRET_KEY=insecure-dev-secret-change-me-in-production
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,astrozor.localhost,api,proxy
DJANGO_CSRF_TRUSTED_ORIGINS=http://astrozor.localhost,http://localhost

# ---- Database (PostgreSQL + PostGIS) ----
POSTGRES_DB=astrozor
POSTGRES_USER=astrozor
POSTGRES_PASSWORD=astrozor

# ---- Future: feature toggles ----
# Set to "false" to disable the publish API on this self-host instance.
PUBLIC_PUBLISH_API_ENABLED=true

# ---- Future: OAuth credentials (Krok 1) ----
# See BLOCKERS.md for how to obtain.
# GITHUB_OAUTH_CLIENT_ID=
# GITHUB_OAUTH_CLIENT_SECRET=
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=

# ---- Future: Zenodo DOI (Krok 11) ----
# ZENODO_SANDBOX_TOKEN=
# ZENODO_PROD_TOKEN=

# ---- Future: Discord test webhook (Krok 9) ----
# DISCORD_TEST_WEBHOOK_URL=

# ---- Future: web-push (Krok 9) ----
# Generate with: docker compose run --rm api python -c "from py_vapid import Vapid; v = Vapid(); v.generate_keys(); v.save_key('/tmp/vapid_private.pem'); v.save_public_key('/tmp/vapid_public.pem')"
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_ADMIN_EMAIL=admin@astrozor.cz
